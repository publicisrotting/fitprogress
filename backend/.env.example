# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change_me

# Monobank Acquiring token (merchant cabinet → Еквайринг та API)
MONO_MERCHANT_TOKEN=your_monobank_acquiring_token
# Optional separate sandbox token
# MONO_MERCHANT_TEST_TOKEN=
PREMIUM_PRICE_UAH=99

# URL Monobank redirects back to after payment
WEB_APP_URL=http://localhost:5174

# Optional public HTTPS webhook (e.g. ngrok) for instant confirmation
# MONO_WEBHOOK_URL=
# MONO_WEBHOOK_PUBKEY_BASE64=

# Optional admin key for /api/billing/monopay/pubkey-import
# ADMIN_API_KEY=
